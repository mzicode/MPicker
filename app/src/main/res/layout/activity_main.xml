<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/demo_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MPicker Demo"
            android:textColor="#222"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/demo_theme_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#EAF4FF"
            android:padding="8dp"
            android:text="当前主题: GREEN"
            android:textColor="#16324F"
            android:textSize="13sp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_theme_green"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="GREEN" />

                <Button
                    android:id="@+id/btn_theme_wechat"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:text="WECHAT_DARK" />

                <Button
                    android:id="@+id/btn_theme_sky"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:text="SKY" />

                <Button
                    android:id="@+id/btn_theme_amber"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:text="AMBER" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/demo_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#F5F5F5"
            android:minHeight="120dp"
            android:padding="8dp"
            android:text="结果回调显示在这里"
            android:textColor="#555"
            android:textSize="12sp" />

        <ImageView
            android:id="@+id/demo_preview"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="8dp"
            android:adjustViewBounds="true"
            android:background="#EEEEEE"
            android:scaleType="centerInside"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_pick_image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="选图片（最多 9 张，网格）" />

        <Button
            android:id="@+id/btn_pick_video"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选视频（最多 3 个，网格）" />

        <Button
            android:id="@+id/btn_pick_audio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选音乐（列表样式）" />

        <Button
            android:id="@+id/btn_pick_mixed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="混合（自定义 mimeType: png+mp4）" />

        <Button
            android:id="@+id/btn_pick_all"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="全部类型" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="系统选择器"
            android:textColor="#222"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_pick_system_photo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="系统 Photo Picker（API 33+，最多 5 张）" />

        <Button
            android:id="@+id/btn_pick_document"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="系统文件选择器（PDF / ZIP / Word，可多选）" />

        <Button
            android:id="@+id/btn_pick_pdf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PDF 文件（自定义封面 / 预览打开）" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="压缩"
            android:textColor="#222"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_pick_compress_image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选图并压缩（智能压缩）" />

        <Button
            android:id="@+id/btn_pick_compress_video"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选择视频并压缩（MediaCodec）" />

        <Button
            android:id="@+id/btn_pick_crop_compress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选图裁剪后压缩" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="裁剪"
            android:textColor="#222"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_pick_crop_square"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选图后裁剪（1:1，最大 1024）" />

        <Button
            android:id="@+id/btn_take_crop_oval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="拍照后圆形裁剪（PNG，最大 512）" />

        <Button
            android:id="@+id/btn_pick_image_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选择图片后编辑（支持多图、文字、画笔、马赛克）" />

        <Button
            android:id="@+id/btn_pick_photo_editor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="第三方 PhotoEditor 编辑图片示例" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="拍照"
            android:textColor="#222"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_take_photo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="独立拍照（不进 picker，直接返回路径）" />

        <Button
            android:id="@+id/btn_take_photo_compress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="拍照并压缩（返回压缩后图片）" />

        <Button
            android:id="@+id/btn_take_video"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="独立录视频（不进 picker，直接返回路径）" />

        <Button
            android:id="@+id/btn_take_video_10s"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="限时录视频（最长 10 秒，倒计时）" />

        <Button
            android:id="@+id/btn_take_video_chain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="链式录视频（返回 MediaEntity）" />

        <Button
            android:id="@+id/btn_take_video_compress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="录视频并压缩（返回压缩后视频）" />

        <Button
            android:id="@+id/btn_pick_with_camera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选图 + 列表首位带相机入口" />

        <Button
            android:id="@+id/btn_pick_video_with_camera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选视频 + 列表首位带录像入口" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="预选（复现上次选中）"
            android:textColor="#222"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/demo_last_picked_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="上次选中: 0 项（先选一次图片）"
            android:textColor="#888"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_pick_with_pre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="再次打开（带上次选中复现）" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="上传"
            android:textColor="#222"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_upload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="上传上次选中的图片（multipart 示例）" />
    </LinearLayout>
</ScrollView>
