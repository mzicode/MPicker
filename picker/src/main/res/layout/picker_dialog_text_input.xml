<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/picker_bg_text_dialog"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/picker_text_dialog_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/picker_crop_text"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/picker_text_dialog_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="×"
            android:textColor="#CCFFFFFF"
            android:textSize="24sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/picker_crop_text_hint"
        android:textColor="#99FFFFFF"
        android:textSize="13sp" />

    <EditText
        android:id="@+id/picker_text_dialog_input"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/picker_bg_text_dialog_input"
        android:hint="@string/picker_crop_text_hint"
        android:imeActionLabel="@string/picker_confirm"
        android:imeActionId="6"
        android:imeOptions="actionDone"
        android:inputType="text"
        android:maxLines="1"
        android:paddingHorizontal="14dp"
        android:singleLine="true"
        android:textColor="#FFFFFF"
        android:textColorHint="#66FFFFFF"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/picker_text_dialog_done"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/picker_bg_confirm_button"
        android:gravity="center"
        android:text="@string/picker_done"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>
